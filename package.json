{
	"scripts": {
		"start": "bun --watch index.ts",
		"deploy": "bun _gen && bun _deploy.ts && x upgrade",
		"upgrade": "bun update --latest",
		"check": "bun run --sequential --no-exit-on-error check:clean check:deno check:oxlint check:biome check:export lint",
		"check:deno": "deno fmt --use-tabs --quiet",
		"check:oxlint": "oxlint --fix-dangerously --quiet",
		"check:biome": "timeout 3s biome check --write --unsafe .",
		"check:export": "ts-unused-exports tsconfig.json",
		"lint": "tsc --noEmit",
		"all": "bun run --sequential --no-exit-on-error upgrade check",
		"check:clean": "rm -rf dist out build"
	},
	"dependencies": {
		"cdk8s": "^2.70.83",
		"cdk8s-plus-33": "^2.5.38",
		"commander": "^15.0.0",
		"p-queue": "^9.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@types/bun": "^1.3.14",
		"typescript": "^7.0.2"
	}
}
